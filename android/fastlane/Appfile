# Path to the Google Play service account JSON key.
# Generate at: Play Console → Setup → API access → Service accounts
# Stored in android/fastlane/signing/ (gitignored). Override with PLAY_STORE_JSON_KEY env var.
json_key_file(ENV["PLAY_STORE_JSON_KEY"] || File.expand_path("signing/where_play_store_api_key.json", __dir__))

package_name("net.af0.where")
