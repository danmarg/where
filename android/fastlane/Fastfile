default_platform(:android)

# Signing for release builds is read from env vars by android/build.gradle.kts:
#   KEYSTORE_FILE     — absolute path to the .jks keystore
#   KEYSTORE_PASSWORD — keystore password
#   KEY_PASSWORD      — key password (alias is hardcoded to "where" in build.gradle.kts)

platform :android do
  desc "Build a debug APK"
  lane :build_debug do
    gradle(
      project_dir: "../",
      task: "assemble",
      build_type: "Debug",
    )
  end

  desc "Build a release AAB (requires signing env vars)"
  lane :build_release do
    gradle(
      project_dir: "../",
      task: "bundle",
      build_type: "Release",
    )
  end

  desc "Build a release AAB and upload to Google Play (internal track)"
  lane :deploy do
    gradle_file = "../build.gradle.kts"
    today = Time.now.strftime("%Y.%m.%d")

    content = File.read(gradle_file)
    current_name = content.match(/versionName\s*=\s*"([^"]+)"/)[1]
    new_version_name = if current_name.start_with?(today)
      "#{today}.#{current_name.split('.').last.to_i + 1}"
    else
      "#{today}.1"
    end

    current_code = content.match(/versionCode\s*=\s*(\d+)/)[1].to_i
    new_version_code = current_code + 1

    UI.message("Updating version name to #{new_version_name} and version code to #{new_version_code}")

    content.gsub!(/(versionName\s*=\s*)"[^"]+"/, "\\1\"#{new_version_name}\"")
    content.gsub!(/(versionCode\s*=\s*)\d+/, "\\1#{new_version_code}")

    File.write(gradle_file, content)

    gradle(
      project_dir: "../",
      task: "bundle",
      build_type: "Release",
    )
    upload_to_play_store(track: "internal", skip_upload_apk: true)
  end

  desc "Promote the internal version to closed testing (alpha)"
  lane :promote_to_closed do
    key_path = ENV["PLAY_STORE_JSON_KEY"] || File.expand_path("~/.config/where/play-store-key.json")
    package_name = CredentialsManager::AppfileConfig.try_fetch_value(:package_name) || "net.af0.where"
    
    UI.message("Promoting version from 'internal' to 'alpha'...")
    UI.message("Using JSON key at: #{key_path}")
    UI.message("Package name: #{package_name}")
    
    upload_to_play_store(
      json_key: key_path,
      package_name: package_name,
      track: "internal",
      track_promote_to: "alpha",
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
