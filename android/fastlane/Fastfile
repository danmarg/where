default_platform(:android)

# Signing for release builds is read from env vars by android/build.gradle.kts:
#   KEYSTORE_FILE     — absolute path to the .jks keystore
#   KEYSTORE_PASSWORD — keystore password
#   KEY_PASSWORD      — key password (alias is hardcoded to "where" in build.gradle.kts)

platform :android do
  desc "Build a debug APK"
  lane :build_debug do
    gradle(
      project_dir: "../",
      task: ":android:assembleStandardGmsDebug",
    )
  end

  desc "Build a release AAB without activity recognition (requires signing env vars)"
  lane :build_release do
    gradle(
      project_dir: "../",
      task: ":android:bundleStandardGmsRelease",
    )
  end

  desc "Build a release AAB with full activity recognition (requires signing env vars)"
  lane :build_release_full do
    gradle(
      project_dir: "../",
      task: ":android:bundleFullGmsRelease",
    )
  end

  def bump_version(gradle_file)
    today = Time.now.strftime("%Y.%m.%d")
    content = File.read(gradle_file)
    current_name = content.match(/versionName\s*=\s*"([^"]+)"/)[1]
    new_version_name = if current_name.start_with?(today)
      "#{today}.#{current_name.split('.').last.to_i + 1}"
    else
      "#{today}.1"
    end
    current_code = content.match(/versionCode\s*=\s*(\d+)/)[1].to_i
    new_version_code = current_code + 1
    UI.message("Updating version name to #{new_version_name} and version code to #{new_version_code}")
    content.gsub!(/(versionName\s*=\s*)"[^"]+"/, "\\1\"#{new_version_name}\"")
    content.gsub!(/(versionCode\s*=\s*)\d+/, "\\1#{new_version_code}")
    File.write(gradle_file, content)
  end

  desc "Build standard AAB (no activity recognition) and upload to Google Play (internal track)"
  lane :deploy do
    bump_version("../build.gradle.kts")
    gradle(
      project_dir: "../",
      task: ":android:bundleStandardGmsRelease",
    )
    upload_to_play_store(track: "internal", skip_upload_apk: true)
  end

  desc "Build full AAB (with activity recognition) and upload to Google Play (internal track)"
  lane :deploy_full do
    bump_version("../build.gradle.kts")
    gradle(
      project_dir: "../",
      task: ":android:bundleFullGmsRelease",
    )
    upload_to_play_store(track: "internal", skip_upload_apk: true)
  end

  desc "Build signed standardGms (universal) + standardFdroid (per-ABI split) release APKs " \
       "for the current versionName and publish them as assets on a GitHub Release tagged " \
       "v<versionName>. The standardFdroid APKs are the signed reference binaries F-Droid's " \
       "Reproducible Builds feature diffs its own build against (see the per-Build `binary:` " \
       "fields in metadata/net.af0.where.yml upstream — one per ABI). " \
       "Signing stays local — nothing here touches GitHub Actions or CI secrets. " \
       "Run this after committing the versionName/versionCode bump (e.g. from deploy/deploy_full) " \
       "so HEAD is the exact commit you want the tag to point at. Requires signing env vars " \
       "and an authenticated `gh` CLI."
  lane :release_github_binaries do
    gradle_file = File.expand_path("../build.gradle.kts", __dir__)
    version_name = File.read(gradle_file).match(/versionName\s*=\s*"([^"]+)"/)[1]
    tag = "v#{version_name}"
    repo = "danmarg/where"

    unless system("git", "rev-parse", "--verify", "--quiet", tag)
      UI.message("Tag #{tag} not found; creating and pushing it at HEAD")
      sh("git", "tag", "-a", tag, "-m", "Release #{version_name}")
      sh("git", "push", "origin", tag)
    end
    unless system("git", "ls-remote", "--exit-code", "--tags", "origin", tag, out: File::NULL)
      UI.user_error!("Tag #{tag} exists locally but isn't pushed to origin — push it before continuing.")
    end

    UI.message("Building signed release APKs for #{tag}...")
    gradle(project_dir: "../", task: ":android:assembleStandardGmsRelease", properties: { "enableAbiSplits" => "true" })
    gradle(project_dir: "../", task: ":android:assembleStandardFdroidRelease", properties: { "enableAbiSplits" => "true" })

    # GMS: Play Store delivery goes through the AAB (bundleStandardGmsRelease, elsewhere); the
    # only APK we publish here is the universal one, purely as a GitHub reference artifact.
    gms_apk = Dir[File.expand_path("../build/outputs/apk/standardGms/release/*-universal-release.apk", __dir__)].first
    UI.user_error!("standardGms universal release APK not found — did signing env vars fail?") unless gms_apk

    # F-Droid: one signed APK per ABI (skip the universal one — F-Droid's Reproducible Builds
    # diffs per-ABI split APKs, matched by versionCode, not a universal APK).
    fdroid_apks = Dir[File.expand_path("../build/outputs/apk/standardFdroid/release/*-release.apk", __dir__)]
      .reject { |apk| apk.include?("-universal-") }
    UI.user_error!("No standardFdroid per-ABI release APKs found — did signing env vars fail?") if fdroid_apks.empty?

    all_apks = [gms_apk] + fdroid_apks
    # Without signing env vars, assembleRelease still succeeds (by design, so CI/F-Droid can
    # build unsigned) but names the output *-unsigned.apk. Refuse to publish that as the
    # reproducible-build reference binary.
    all_apks.each do |apk|
      UI.user_error!("#{apk} is unsigned — check KEYSTORE_FILE/KEYSTORE_PASSWORD/KEY_PASSWORD") if apk.include?("-unsigned")
    end

    unless system("gh", "release", "view", tag, "-R", repo, out: File::NULL, err: File::NULL)
      sh("gh", "release", "create", tag, "--title", tag, "--notes", "Release #{version_name}", "-R", repo)
    end
    all_apks.each do |apk|
      sh("gh", "release", "upload", tag, apk, "--clobber", "-R", repo)
    end

    UI.success("Uploaded signed standardGms (universal) + standardFdroid (#{fdroid_apks.size} ABIs) APKs to GitHub release #{tag}")
  end

  desc "Promote the internal version to closed testing (alpha)"
  lane :promote_to_closed do
    key_path = ENV["PLAY_STORE_JSON_KEY"] || File.expand_path("signing/where_play_store_api_key.json", __dir__)
    package_name = CredentialsManager::AppfileConfig.try_fetch_value(:package_name) || "net.af0.where"
    
    UI.message("Promoting version from 'internal' to 'alpha'...")
    UI.message("Using JSON key at: #{key_path}")
    UI.message("Package name: #{package_name}")
    
    upload_to_play_store(
      json_key: key_path,
      package_name: package_name,
      track: "internal",
      track_promote_to: "alpha",
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
